# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
site-packages/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
.env
.python-version

# ── Dataset (7,200 generated images — never commit) ───────────────────────────
dataset/

# ── Checkpoints — ignore large weights, KEEP onnx/csv/png ────────────────────
checkpoints/*.pt
checkpoints/*.pth
checkpoints/*.ckpt
checkpoints/*.safetensors
# checkpoints/omnivision3d.onnx  — tracked (8.5 MB, needed for Pi deploy)
# checkpoints/training_log.csv   — tracked (training history)
# checkpoints/training_curve.png — tracked (training curve)

# ── Runtime logs (generated at mission time — not source files) ───────────────
pi_deploy/logs/*.log
pi_deploy/logs/*.csv
logs/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb
!colab_training.ipynb

# ── Experiment tracking ───────────────────────────────────────────────────────
runs/
wandb/
mlruns/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini
ehthumbs.db

# ── IDEs ──────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*.suo
*.user

# ── Kill switch (file-based drone stop signal — never commit) ────────────────
pi_deploy/KILL

# ── Misc ──────────────────────────────────────────────────────────────────────
=0*
tests/test_images/
tests/test_results/
tests/test_video.mp4
tests/test_video_result.mp4
yolo_dataset.zip
yolov8n.pt
